  transition:all 0.2s;
}
.footer-socials a:hover{background:rgba(212,168,67,0.15);border-color:rgba(212,168,67,0.3);color:var(--gold)}
.footer-col-h{font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:white;margin-bottom:20px}
.footer-links{list-style:none;display:flex;flex-direction:column;gap:10px}
.footer-links a{font-size:0.85rem;color:rgba(255,255,255,0.45);text-decoration:none;font-weight:300;transition:color 0.2s}
.footer-links a:hover{color:var(--gold)}
.footer-bottom{display:flex;justify-content:space-between;align-items:center;font-size:0.75rem;color:rgba(255,255,255,0.3)}

/* MOBILE MENU */
.mob-menu{
  display:none;position:fixed;inset:0;z-index:490;
  background:var(--ink);flex-direction:column;
  justify-content:center;align-items:center;gap:40px;
}
.mob-menu.open{display:flex}
.mob-menu a{font-family:var(--display);font-size:2.2rem;font-weight:400;color:rgba(255,255,255,0.8);text-decoration:none;transition:color 0.2s}
.mob-menu a:hover{color:var(--gold)}
.mob-close{position:absolute;top:24px;right:28px;background:none;border:none;color:white;font-size:1.8rem;cursor:pointer}

/* RESPONSIVE */
@media(max-width:1100px){
  .stats-strip{grid-template-columns:repeat(2,1fr)}
  .benefits-grid{grid-template-columns:repeat(2,1fr)}
  .process-track{grid-template-columns:repeat(2,1fr);gap:48px}
  .process-track::before{display:none}
  .testi-grid{grid-template-columns:1fr 1fr}
  .tcard.big{grid-row:span 1}
  .footer-top{grid-template-columns:1fr 1fr}
}
@media(max-width:768px){
  nav{padding:18px 24px}
  .nav-links{display:none}
  .hamburger{display:flex}
  .hero{grid-template-columns:1fr;min-height:auto}
  .hero-left{padding:100px 24px 48px}
  .hero-right{height:80vw;min-height:300px}
  .hero-photo-wrap{width:80%;margin:0 auto}
  .fc-1,.fc-2,.fc-3,.hero-lang-badge{display:none}
  .stats-strip{grid-template-columns:repeat(2,1fr);padding:40px 24px}
  section,
  .pain,.solution,.specs,.process,.testi,.about,.pricing,.fcta{padding:72px 24px}
  .pain-grid,.solution-header,.specs-header,.process-header,.testi-header,.about-grid,.pain-grid{grid-template-columns:1fr;gap:40px}
  .testi-header{flex-direction:column;align-items:flex-start;gap:20px}
  .testi-grid{grid-template-columns:1fr}
  .benefits-grid{grid-template-columns:1fr}
  .specs-grid{grid-template-columns:1fr}
  .process-track{grid-template-columns:1fr;gap:40px}
  .price-grid{grid-template-columns:1fr}
  .footer-top{grid-template-columns:1fr}
  footer{padding:60px 24px 36px}
  .footer-bottom{flex-direction:column;gap:8px;text-align:center}
  .fcta-trust{gap:16px}
  .hero-proof{flex-wrap:wrap}
  .about-badge{right:16px}
}
</style>
