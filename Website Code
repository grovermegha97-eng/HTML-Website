  color:var(--royal);font-size:0.65rem;font-weight:800;text-transform:uppercase;
  letter-spacing:0.12em;padding:5px 18px;border-radius:100px;
  white-space:nowrap;
}
.pcard-plan{font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.15em;color:rgba(255,255,255,0.5);margin-bottom:20px}
.pcard.hot .pcard-plan{color:var(--gold)}
.pcard-price{
  font-family:var(--display);font-size:3.2rem;font-weight:900;
  color:white;line-height:1;margin-bottom:6px;
}
.pcard.hot .pcard-price{
  background:linear-gradient(135deg,var(--gold),var(--gold-bright));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.pcard-unit{font-size:0.8rem;color:rgba(255,255,255,0.4);margin-bottom:36px;font-weight:300}
.pcard-features{list-style:none;display:flex;flex-direction:column;gap:14px;margin-bottom:40px}
.pcard-features li{
  font-size:0.875rem;color:rgba(255,255,255,0.65);
  display:flex;align-items:flex-start;gap:10px;font-weight:300;
}
.pcard.hot .pcard-features li{color:rgba(255,255,255,0.85)}
.pcard-features li::before{
  content:'✓';color:var(--gold);font-weight:700;font-size:0.8rem;flex-shrink:0;margin-top:2px;
}
.pcard-btn{
  display:block;text-align:center;text-decoration:none;
  padding:15px 24px;border-radius:100px;
  font-size:0.82rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;
  border:1.5px solid rgba(255,255,255,0.2);color:white;
  transition:all 0.25s;
}
.pcard-btn:hover{border-color:rgba(255,255,255,0.5);background:rgba(255,255,255,0.08)}
.pcard.hot .pcard-btn{
  background:linear-gradient(135deg,var(--gold),var(--gold-bright));
  border-color:transparent;color:var(--royal);
  box-shadow:0 8px 28px rgba(212,168,67,0.35);
}
.pcard.hot .pcard-btn:hover{box-shadow:0 12px 40px rgba(212,168,67,0.5);transform:translateY(-2px)}
.price-note{text-align:center;margin-top:48px;font-family:var(--display);font-size:1.05rem;font-style:italic;color:rgba(255,255,255,0.35)}

/* FINAL CTA */
.fcta{
  padding:150px 80px;
  background:var(--cream);
  text-align:center;
  position:relative;overflow:hidden;
}
.fcta-orb1{
  position:absolute;top:-100px;left:-100px;
  width:400px;height:400px;border-radius:50%;
  background:radial-gradient(circle,rgba(91,53,213,0.07),transparent);
}
.fcta-orb2{
  position:absolute;bottom:-100px;right:-100px;
  width:400px;height:400px;border-radius:50%;
