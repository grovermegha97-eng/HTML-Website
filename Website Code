  font-size:clamp(2.5rem,5vw,5rem);
  font-weight:900;line-height:1.0;
  color:var(--royal);margin-bottom:20px;
}
.fcta-h em{
  font-style:italic;
  background:linear-gradient(90deg,var(--violet),var(--gold));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.fcta-sub{font-size:1rem;color:var(--muted);line-height:1.75;font-weight:300;margin-bottom:52px;max-width:520px;margin-left:auto;margin-right:auto}
.fcta-btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-bottom:48px}
.fcta-trust{
