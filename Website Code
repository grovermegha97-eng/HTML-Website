}
.cred-text{font-size:0.88rem;color:var(--ink);font-weight:400}
.about-langs{
  display:flex;gap:12px;flex-wrap:wrap;margin-bottom:36px;
}
.lang-tag{
  display:flex;align-items:center;gap:8px;
  background:white;border:1px solid var(--border);
  border-radius:100px;padding:8px 16px;
  font-size:0.8rem;font-weight:600;color:var(--royal);
}
.lang-tag-dot{width:8px;height:8px;border-radius:50%}

/* PRICING */
.pricing{
  background:var(--royal);
  padding:110px 80px;
  position:relative;overflow:hidden;
}
.pricing::before{
  content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 50% 0%,rgba(91,53,213,0.4),transparent 70%);
}
.pricing-inner{position:relative;z-index:1}
.pricing-header{text-align:center;margin-bottom:70px}
.pricing-header .sec-h{margin:0 auto 16px;max-width:600px}
.pricing-sub{font-size:0.95rem;color:rgba(255,255,255,0.55);font-weight:300;max-width:500px;margin:0 auto}
.price-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
.pcard{
  background:rgba(255,255,255,0.05);
  border:1px solid rgba(255,255,255,0.1);
  border-radius:24px;padding:48px 36px;
