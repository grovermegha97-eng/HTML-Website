/* PROCESS */
.process{padding:110px 80px;background:white}
.process-header{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:end;margin-bottom:90px}
.process-note{font-size:0.95rem;color:var(--muted);line-height:1.8;font-weight:300;align-self:end}
.process-track{
