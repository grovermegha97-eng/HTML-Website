}
.about-badge-level{font-family:var(--display);font-size:2.2rem;font-weight:900;line-height:1}
.about-badge-label{font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;opacity:0.7;margin-top:2px}
.about-content{}
.about-intro{
  font-family:var(--display);font-size:1.2rem;font-style:italic;font-weight:400;
  color:var(--muted);line-height:1.7;margin-bottom:28px;
}
.about-body{font-size:0.95rem;color:var(--ink);line-height:1.85;font-weight:300;opacity:0.8;margin-bottom:36px}
.cred-list{display:flex;flex-direction:column;gap:0;margin-bottom:44px}
.cred-row{
  display:flex;align-items:center;gap:16px;
