  opacity:0.3;
}
.pstep{padding:0 24px 0 0;position:relative}
.pstep-bubble{
  width:78px;height:78px;border-radius:50%;
  background:linear-gradient(135deg,var(--royal-light),var(--royal-mid));
  border:2px solid rgba(91,53,213,0.25);
  display:flex;align-items:center;justify-content:center;
  font-family:var(--display);font-size:1.8rem;font-weight:700;
  color:var(--gold);margin-bottom:28px;
  position:relative;z-index:1;
  transition:transform 0.3s,box-shadow 0.3s;
}
.pstep:hover .pstep-bubble{
  transform:scale(1.1);
  box-shadow:0 8px 30px rgba(26,11,75,0.3);
}
.pstep-title{font-family:var(--display);font-size:1.25rem;font-weight:700;color:var(--royal);margin-bottom:10px}
.pstep-text{font-size:0.85rem;color:var(--muted);line-height:1.75;font-weight:300}

/* TESTIMONIALS */
.testi{background:var(--smoke);padding:110px 80px}
.testi-header{
