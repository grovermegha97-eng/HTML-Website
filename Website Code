<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Clase con Meg — Spanish Tutoring That Gets Results</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;0,900;1,400;1,700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --royal:#1a0b4b;
  --royal-mid:#2d1572;
  --royal-light:#3d22a0;
  --violet:#5b35d5;
  --lavender:#8b6fe8;
  --gold:#d4a843;
  --gold-bright:#f0c843;
  --gold-pale:#f5e4a8;
  --cream:#fdfaf4;
  --white:#ffffff;
  --ink:#0d0722;
  --smoke:#f0ecfa;
  --muted:#7a6e9e;
  --border:rgba(26,11,75,0.12);
  --display:'Playfair Display',Georgia,serif;
  --sans:'Outfit',system-ui,sans-serif;
}
html{scroll-behavior:smooth}
body{
  background:var(--cream);
  color:var(--ink);
  font-family:var(--sans);
  overflow-x:hidden;
  cursor:none;
}

/* CUSTOM CURSOR */
.cursor{
  position:fixed;width:12px;height:12px;
  background:var(--gold);border-radius:50%;
  pointer-events:none;z-index:99999;
  transform:translate(-50%,-50%);
  transition:transform 0.1s,width 0.3s,height 0.3s,background 0.3s;
  mix-blend-mode:multiply;
}
.cursor-ring{
  position:fixed;width:40px;height:40px;
  border:1.5px solid var(--violet);border-radius:50%;
  pointer-events:none;z-index:99998;
  transform:translate(-50%,-50%);
  transition:transform 0.18s ease,width 0.3s,height 0.3s,opacity 0.3s;
  opacity:0.6;
}

/* ANIMATIONS */
@keyframes fadeUp{from{opacity:0;transform:translateY(40px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes shimmer{
  0%{background-position:-200% center}
  100%{background-position:200% center}
}
@keyframes float{
  0%,100%{transform:translateY(0) rotate(-2deg)}
  50%{transform:translateY(-12px) rotate(-2deg)}
}
@keyframes float2{
  0%,100%{transform:translateY(0) rotate(3deg)}
  50%{transform:translateY(-8px) rotate(3deg)}
}
@keyframes spinSlow{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
@keyframes marquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
@keyframes pulseRing{
  0%{box-shadow:0 0 0 0 rgba(212,168,67,0.4)}
  70%{box-shadow:0 0 0 16px rgba(212,168,67,0)}
  100%{box-shadow:0 0 0 0 rgba(212,168,67,0)}
}
@keyframes gradShift{
  0%{background-position:0% 50%}
  50%{background-position:100% 50%}
  100%{background-position:0% 50%}
}
@keyframes countUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}

.reveal{opacity:0;transform:translateY(32px);transition:opacity 0.8s cubic-bezier(0.16,1,0.3,1),transform 0.8s cubic-bezier(0.16,1,0.3,1)}
.reveal.on{opacity:1;transform:translateY(0)}
.reveal-left{opacity:0;transform:translateX(-40px);transition:opacity 0.8s cubic-bezier(0.16,1,0.3,1),transform 0.8s cubic-bezier(0.16,1,0.3,1)}
.reveal-left.on{opacity:1;transform:translateX(0)}
.reveal-right{opacity:0;transform:translateX(40px);transition:opacity 0.8s cubic-bezier(0.16,1,0.3,1),transform 0.8s cubic-bezier(0.16,1,0.3,1)}
.reveal-right.on{opacity:1;transform:translateX(0)}
.d1{transition-delay:0.1s}.d2{transition-delay:0.2s}.d3{transition-delay:0.3s}.d4{transition-delay:0.45s}.d5{transition-delay:0.6s}

/* NAV */
nav{
  position:fixed;top:0;left:0;right:0;z-index:500;
  padding:22px 60px;
  display:flex;justify-content:space-between;align-items:center;
  transition:all 0.4s;
}
nav.solid{
  background:rgba(13,7,34,0.92);
  backdrop-filter:blur(20px);
  padding:16px 60px;
  box-shadow:0 1px 0 rgba(255,255,255,0.06);
}
.logo{
  font-family:var(--display);
  font-size:1.5rem;font-weight:700;
  color:var(--white);text-decoration:none;
  display:flex;align-items:center;gap:10px;
}
.logo-badge{
  width:36px;height:36px;
  background:linear-gradient(135deg,var(--gold),var(--gold-bright));
  border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:1rem;font-weight:900;color:var(--royal);
  font-family:var(--sans);
}
.logo span{color:var(--gold)}
.nav-links{display:flex;gap:32px;align-items:center;list-style:none}
.nav-links a{
  font-size:0.8rem;font-weight:500;text-transform:uppercase;letter-spacing:0.1em;
  color:rgba(255,255,255,0.7);text-decoration:none;
  transition:color 0.2s;
}
.nav-links a:hover{color:var(--gold)}
.nav-btn{
  background:linear-gradient(135deg,var(--gold),var(--gold-bright));
  color:var(--royal)!important;
  padding:10px 24px!important;border-radius:100px!important;
  font-weight:700!important;letter-spacing:0.05em!important;
  opacity:1!important;
  animation:pulseRing 3s ease infinite;
}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:none;background:none;border:none}
.hamburger span{width:22px;height:2px;background:white;transition:0.3s}

/* HERO */
.hero{
  min-height:100vh;
  background:linear-gradient(135deg,#0d0722 0%,#1a0b4b 40%,#2d1572 70%,#1a0b4b 100%);
  background-size:400% 400%;
  animation:gradShift 12s ease infinite;
  display:grid;grid-template-columns:1fr 1fr;
  position:relative;overflow:hidden;
}
.hero::before{
  content:'';position:absolute;inset:0;
  background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.025'%3E%3Ccircle cx='30' cy='30' r='1'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
}
/* GLOWING ORBS */
.orb{
  position:absolute;border-radius:50%;
  filter:blur(80px);pointer-events:none;
}
.orb1{width:500px;height:500px;background:rgba(91,53,213,0.35);top:-100px;right:30%;animation:float 8s ease-in-out infinite}
.orb2{width:350px;height:350px;background:rgba(212,168,67,0.15);bottom:-50px;left:10%;animation:float2 10s ease-in-out infinite}
.orb3{width:250px;height:250px;background:rgba(139,111,232,0.2);top:40%;right:5%;animation:float 7s ease-in-out 2s infinite}

.hero-left{
  display:flex;flex-direction:column;justify-content:center;
  padding:140px 60px 80px 80px;
  position:relative;z-index:2;
}
.hero-tag{
  display:inline-flex;align-items:center;gap:10px;
  background:rgba(255,255,255,0.08);
  border:1px solid rgba(212,168,67,0.3);
  padding:8px 18px;border-radius:100px;
  margin-bottom:32px;
  width:fit-content;
  animation:fadeUp 0.8s cubic-bezier(0.16,1,0.3,1) 0.2s both;
}
.hero-tag-dot{width:7px;height:7px;background:var(--gold);border-radius:50%;animation:pulseRing 2s ease infinite}
.hero-tag span{font-size:0.75rem;font-weight:600;text-transform:uppercase;letter-spacing:0.12em;color:var(--gold-pale)}
.hero-h1{
  font-family:var(--display);
  font-size:clamp(2.8rem,5vw,5.5rem);
  font-weight:900;line-height:1.0;
  color:var(--white);margin-bottom:10px;
  animation:fadeUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.35s both;
}
.hero-h1 em{
  font-style:italic;
  background:linear-gradient(90deg,var(--gold),var(--gold-bright),var(--gold));
  background-size:200% auto;
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  animation:shimmer 3s linear infinite;
}
.hero-h2{
  font-family:var(--display);
  font-size:clamp(2.8rem,5vw,5.5rem);
  font-weight:400;font-style:italic;line-height:1.0;
  color:rgba(255,255,255,0.55);
  margin-bottom:36px;
  animation:fadeUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.45s both;
}
.hero-sub{
  font-size:1.05rem;font-weight:300;line-height:1.8;
  color:rgba(255,255,255,0.65);
  max-width:420px;margin-bottom:48px;
  animation:fadeUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.55s both;
}
.hero-sub strong{color:var(--gold-pale);font-weight:600}
.hero-actions{
  display:flex;gap:16px;align-items:center;flex-wrap:wrap;
  animation:fadeUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.7s both;
}
.btn-gold{
  background:linear-gradient(135deg,var(--gold) 0%,var(--gold-bright) 50%,var(--gold) 100%);
  background-size:200% auto;
  color:var(--royal);
  padding:17px 38px;border-radius:100px;
  font-size:0.88rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;
  text-decoration:none;border:none;cursor:none;
  transition:background-position 0.4s,transform 0.2s,box-shadow 0.3s;
  box-shadow:0 8px 30px rgba(212,168,67,0.35);
}
.btn-gold:hover{background-position:right center;transform:translateY(-3px);box-shadow:0 12px 40px rgba(212,168,67,0.5)}
.btn-outline-white{
  color:white;
  padding:16px 32px;border-radius:100px;
  font-size:0.88rem;font-weight:500;letter-spacing:0.05em;
  text-decoration:none;
  border:1.5px solid rgba(255,255,255,0.25);
  transition:border-color 0.2s,background 0.2s;
  display:flex;align-items:center;gap:10px;
}
.btn-outline-white:hover{border-color:rgba(255,255,255,0.6);background:rgba(255,255,255,0.07)}
.hero-proof{
  display:flex;align-items:center;gap:16px;margin-top:48px;
  animation:fadeUp 0.9s cubic-bezier(0.16,1,0.3,1) 0.85s both;
}
.hero-avatars{display:flex}
.hero-avatars span{
  width:36px;height:36px;border-radius:50%;
  border:2px solid var(--royal-mid);
  display:flex;align-items:center;justify-content:center;
  font-size:0.75rem;font-weight:700;color:white;
  margin-left:-10px;
}
.hero-avatars span:first-child{margin-left:0}
.hero-proof-text{font-size:0.82rem;color:rgba(255,255,255,0.6);line-height:1.4}
.hero-proof-text strong{color:var(--gold-pale);font-weight:600}
.hero-right{
  position:relative;display:flex;
  align-items:flex-end;justify-content:center;
  overflow:visible;z-index:2;
}
.hero-photo-wrap{
  position:relative;
  width:90%;max-width:480px;
  margin-bottom:0;
  animation:fadeIn 1.2s ease 0.5s both;
}
.hero-photo-wrap img{
  width:100%;
  display:block;
  object-fit:cover;
  object-position:center top;
  mask-image:linear-gradient(to bottom,black 60%,transparent 100%);
  -webkit-mask-image:linear-gradient(to bottom,black 60%,transparent 100%);
  filter:drop-shadow(0 20px 60px rgba(0,0,0,0.5));
}
.floating-card{
  position:absolute;
  background:rgba(255,255,255,0.08);
  backdrop-filter:blur(16px);
  border:1px solid rgba(255,255,255,0.15);
  border-radius:16px;
  padding:16px 20px;
  color:white;
}
.fc-1{top:12%;left:-30px;animation:float 5s ease-in-out infinite}
.fc-2{top:35%;right:-20px;animation:float2 6s ease-in-out 1s infinite}
.fc-3{bottom:20%;left:-20px;animation:float 7s ease-in-out 2s infinite}
.fc-num{font-family:var(--display);font-size:1.8rem;font-weight:700;color:var(--gold-bright);line-height:1}
.fc-label{font-size:0.7rem;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.6);margin-top:2px}
.fc-flag{font-size:1.4rem;margin-bottom:4px}
.fc-country{font-size:0.8rem;font-weight:600;color:white}
.fc-city{font-size:0.68rem;color:rgba(255,255,255,0.55)}
.hero-lang-badge{
  position:absolute;bottom:100px;right:-30px;
  background:linear-gradient(135deg,var(--gold),var(--gold-bright));
  color:var(--royal);
  padding:12px 20px;border-radius:12px;
  font-family:var(--display);font-size:1.4rem;font-weight:700;font-style:italic;
  box-shadow:0 8px 30px rgba(212,168,67,0.4);
  animation:float2 5s ease-in-out 0.5s infinite;
}

/* MARQUEE */
.marquee-wrap{background:var(--gold);padding:14px 0;overflow:hidden}
.marquee-track{display:flex;white-space:nowrap;animation:marquee 20s linear infinite}
.marquee-item{
  display:flex;align-items:center;gap:20px;padding-right:40px;
  font-size:0.8rem;font-weight:700;text-transform:uppercase;letter-spacing:0.12em;color:var(--royal);
}
.m-star{font-size:0.7rem;opacity:0.5}

/* STATS STRIP */
.stats-strip{
  background:var(--royal);
  padding:60px 80px;
  display:grid;grid-template-columns:repeat(4,1fr);
  gap:2px;
}
.stat-item{
  padding:40px 36px;
  background:rgba(255,255,255,0.03);
  text-align:center;
  border-right:1px solid rgba(255,255,255,0.07);
  transition:background 0.3s;
}
.stat-item:last-child{border-right:none}
.stat-item:hover{background:rgba(255,255,255,0.06)}
.stat-num{
  font-family:var(--display);font-size:3.2rem;font-weight:900;
  background:linear-gradient(135deg,var(--gold),var(--gold-bright));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  line-height:1;margin-bottom:8px;
}
.stat-label{font-size:0.78rem;font-weight:500;text-transform:uppercase;letter-spacing:0.1em;color:rgba(255,255,255,0.5)}
.stat-detail{font-size:0.72rem;color:rgba(255,255,255,0.3);margin-top:4px;font-style:italic}

/* SECTION SHARED */
.sec-tag{
  display:inline-flex;align-items:center;gap:10px;
  margin-bottom:16px;
}
.sec-tag span{font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.18em;color:var(--violet)}
.sec-tag-line{width:28px;height:2px;background:var(--gold);border-radius:2px}
.sec-h{
  font-family:var(--display);
  font-size:clamp(2rem,3.5vw,3.6rem);
  font-weight:700;line-height:1.1;
  color:var(--royal);margin-bottom:18px;
}
.sec-h em{font-style:italic;color:var(--violet)}
.sec-h-white{color:var(--white)}
.sec-h-white em{color:var(--gold)}

/* PAIN SECTION */
.pain{
  background:var(--ink);
  padding:110px 80px;
  position:relative;overflow:hidden;
}
.pain-bg-text{
  position:absolute;font-family:var(--display);font-size:28vw;font-weight:900;
  color:rgba(255,255,255,0.018);top:50%;left:50%;
  transform:translate(-50%,-50%);line-height:1;pointer-events:none;
  white-space:nowrap;
}
.pain-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
.pain-list{display:flex;flex-direction:column;gap:0}
.pain-row{
  display:flex;gap:24px;padding:28px 0;
  border-bottom:1px solid rgba(255,255,255,0.06);
  align-items:flex-start;
  transition:padding-left 0.3s;
}
.pain-row:hover{padding-left:8px}
.pain-icon{
  width:48px;height:48px;border-radius:12px;
  display:flex;align-items:center;justify-content:center;
  font-size:1.4rem;flex-shrink:0;
  background:rgba(91,53,213,0.15);
  border:1px solid rgba(91,53,213,0.2);
}
.pain-content strong{display:block;font-size:1rem;font-weight:600;color:white;margin-bottom:4px}
.pain-content p{font-size:0.875rem;color:rgba(255,255,255,0.5);line-height:1.7;font-weight:300}
.pain-visual{
  background:linear-gradient(135deg,rgba(26,11,75,0.8),rgba(45,21,114,0.6));
  border:1px solid rgba(91,53,213,0.25);
  border-radius:20px;padding:48px 40px;
  position:relative;overflow:hidden;
}
.pain-visual::before{
  content:'';position:absolute;top:-40px;right:-40px;
  width:200px;height:200px;
  background:radial-gradient(circle,rgba(212,168,67,0.15),transparent);
  border-radius:50%;
}
.pain-q{
  font-family:var(--display);font-size:3rem;
  background:linear-gradient(135deg,var(--gold),var(--gold-bright));
  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  margin-bottom:16px;line-height:1;
}
.pain-quote{
  font-family:var(--display);font-size:1.35rem;font-style:italic;font-weight:400;
  color:rgba(255,255,255,0.85);line-height:1.6;margin-bottom:24px;
}
.pain-who{font-size:0.78rem;font-weight:600;text-transform:uppercase;letter-spacing:0.12em;color:var(--gold)}
.pain-where{font-size:0.72rem;color:rgba(255,255,255,0.4);margin-top:3px;font-style:italic}
.pain-divider{height:1px;background:rgba(255,255,255,0.08);margin:28px 0}
.pain-result{
  display:flex;align-items:center;gap:14px;
  background:rgba(212,168,67,0.1);
  border:1px solid rgba(212,168,67,0.2);
  border-radius:12px;padding:16px 20px;
}
.pain-result-icon{font-size:1.6rem}
.pain-result-text{font-size:0.88rem;color:var(--gold-pale);font-weight:500;line-height:1.45}

/* SOLUTION */
.solution{padding:110px 80px;background:var(--cream)}
.solution-header{
  display:grid;grid-template-columns:1fr 1fr;gap:60px;
  align-items:end;margin-bottom:80px;
}
.solution-intro{
  font-size:0.95rem;color:var(--muted);line-height:1.85;font-weight:300;
  padding-bottom:4px;align-self:end;
}
.benefits-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:20px;
}
.bcard{
  background:white;
  border-radius:20px;padding:40px 32px;
  border:1px solid var(--border);
  position:relative;overflow:hidden;
  transition:transform 0.35s cubic-bezier(0.16,1,0.3,1),box-shadow 0.35s,border-color 0.3s;
}
.bcard:hover{
  transform:translateY(-8px);
  box-shadow:0 24px 60px rgba(26,11,75,0.12);
  border-color:rgba(91,53,213,0.25);
}
.bcard::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(135deg,rgba(91,53,213,0.04),transparent);
  opacity:0;transition:opacity 0.3s;
}
.bcard:hover::after{opacity:1}
.bcard-icon{
  width:52px;height:52px;border-radius:14px;
  background:linear-gradient(135deg,rgba(91,53,213,0.1),rgba(45,21,114,0.15));
  display:flex;align-items:center;justify-content:center;
  font-size:1.5rem;margin-bottom:20px;
  border:1px solid rgba(91,53,213,0.12);
}
.bcard-title{font-family:var(--display);font-size:1.25rem;font-weight:700;color:var(--royal);margin-bottom:10px}
.bcard-text{font-size:0.85rem;color:var(--muted);line-height:1.75;font-weight:300}

/* SPECIALIZATIONS */
.specs{
  background:var(--royal);
  padding:110px 80px;
  position:relative;overflow:hidden;
}
.specs::before{
  content:'';position:absolute;inset:0;
  background:
    radial-gradient(ellipse at 20% 50%,rgba(91,53,213,0.3),transparent 60%),
    radial-gradient(ellipse at 80% 20%,rgba(212,168,67,0.12),transparent 50%);
}
.specs-inner{position:relative;z-index:1}
.specs-header{
  display:grid;grid-template-columns:1fr 1fr;gap:60px;
  align-items:end;margin-bottom:70px;
}
.specs-note{
  font-size:0.95rem;color:rgba(255,255,255,0.55);line-height:1.8;font-weight:300;
  align-self:end;padding-bottom:4px;
}
.specs-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px}
.scard{
  background:rgba(255,255,255,0.05);
  border:1px solid rgba(255,255,255,0.1);
  border-radius:20px;padding:36px 32px;
  transition:background 0.3s,border-color 0.3s,transform 0.3s;
  position:relative;overflow:hidden;
}
.scard:hover{
  background:rgba(255,255,255,0.09);
  border-color:rgba(212,168,67,0.35);
  transform:translateY(-4px);
}
.scard::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:linear-gradient(90deg,var(--gold),var(--gold-bright));
  opacity:0;transition:opacity 0.3s;
}
.scard:hover::before{opacity:1}
.scard-flag{font-size:2rem;margin-bottom:16px;display:block}
.scard-name{font-family:var(--display);font-size:1.4rem;font-weight:700;color:white;margin-bottom:4px}
.scard-sub{font-size:0.82rem;font-style:italic;color:rgba(255,255,255,0.5);margin-bottom:18px;font-weight:300}
.scard-chips{display:flex;flex-wrap:wrap;gap:6px}
.chip{
