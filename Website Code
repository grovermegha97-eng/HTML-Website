  -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
}
.testi-stars{color:var(--gold);font-size:1.1rem;letter-spacing:3px;margin:4px 0}
.testi-count{font-size:0.78rem;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em}
.testi-grid{
  display:grid;
  grid-template-columns:1.5fr 1fr 1fr;
  grid-template-rows:auto auto;
  gap:20px;
}
.tcard{
  background:white;border-radius:20px;padding:36px;
  border:1px solid transparent;
  transition:border-color 0.3s,transform 0.3s,box-shadow 0.3s;
  position:relative;overflow:hidden;
}
.tcard:hover{border-color:rgba(91,53,213,0.2);transform:translateY(-4px);box-shadow:0 16px 50px rgba(26,11,75,0.08)}
.tcard.big{
  background:linear-gradient(135deg,var(--royal),var(--royal-mid));
  grid-row:span 2;
}
.tcard.big:hover{box-shadow:0 20px 60px rgba(26,11,75,0.35)}
.tcard-loc{
  display:flex;align-items:center;gap:8px;
  margin-bottom:18px;
}
.tcard-flag{font-size:1.1rem}
.tcard-city{font-size:0.72rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;color:var(--violet)}
.tcard.big .tcard-city{color:var(--gold)}
.tcard-stars{color:var(--gold);font-size:0.85rem;letter-spacing:2px;margin-bottom:16px}
.tcard-text{
  font-family:var(--display);font-size:1.02rem;font-style:italic;
  font-weight:400;color:var(--ink);line-height:1.65;margin-bottom:24px;
}
.tcard.big .tcard-text{color:rgba(255,255,255,0.85);font-size:1.15rem}
.tcard-author{display:flex;align-items:center;gap:12px}
.tcard-av{
  width:40px;height:40px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:0.85rem;font-weight:700;flex-shrink:0;
}
.tcard-name{font-size:0.88rem;font-weight:700;color:var(--royal)}
.tcard.big .tcard-name{color:white}
.tcard-role{font-size:0.72rem;color:var(--muted);margin-top:2px}
.tcard.big .tcard-role{color:rgba(255,255,255,0.5)}
.tcard-quote-mark{
  position:absolute;top:20px;right:24px;
  font-family:var(--display);font-size:5rem;line-height:1;
  color:rgba(91,53,213,0.08);font-weight:700;
}
.tcard.big .tcard-quote-mark{color:rgba(255,255,255,0.06)}

/* ABOUT */
.about{padding:110px 80px;background:var(--cream)}
.about-grid{display:grid;grid-template-columns:1fr 1.3fr;gap:90px;align-items:center}
.about-img-col{position:relative}
.about-img-frame{
  border-radius:24px;overflow:hidden;
  aspect-ratio:3/4;
  box-shadow:0 30px 80px rgba(26,11,75,0.2);
  position:relative;
}
.about-img-frame img{
  width:100%;height:100%;object-fit:cover;
  object-position:center top;
  transition:transform 0.6s cubic-bezier(0.16,1,0.3,1);
}
.about-img-frame:hover img{transform:scale(1.03)}
.about-img-frame::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(to bottom,transparent 50%,rgba(13,7,34,0.4) 100%);
}
.about-decor{
  position:absolute;
  bottom:-24px;right:-24px;
  width:140px;height:140px;
  border:3px solid var(--gold);border-radius:20px;
  opacity:0.3;z-index:-1;
}
.about-badge{
  position:absolute;top:30px;right:-28px;
  background:linear-gradient(135deg,var(--gold),var(--gold-bright));
  color:var(--royal);
  padding:18px 22px;border-radius:16px;
  text-align:center;
  box-shadow:0 12px 40px rgba(212,168,67,0.4);
